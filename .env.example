# Chave da API do WakaTime.
WAKATIME_API_KEY=

# URL de conexão do app com o PostgreSQL/Supabase.
# Em produção/serverless, use o Session Pooler ou Transaction Pooler do Supabase.
DATABASE_URL=

# URL para Prisma CLI/migrations.
# Use Direct Connection em ambiente com IPv6 ou Session Pooler em IPv4.
DIRECT_URL=

# Opcional: usa Supabase Storage para comprovantes privados.
# Sem estas variáveis, o MVP usa o PostgreSQL privado como fallback.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=payment-receipts

# Segredo do Vercel Cron para a sincronização automática do WakaTime.
# Defina o mesmo valor em Project Settings → Environment Variables.
# O cron (vercel.json) chama /api/cron/wakatime-sync com Authorization: Bearer <CRON_SECRET>.
# Sem este segredo, a rota de cron é recusada (apenas o botão manual funciona).
CRON_SECRET=
