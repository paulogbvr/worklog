# Chave da API do WakaTime.
WAKATIME_API_KEY=

# URL de conexão do app com o PostgreSQL/Supabase.
# Em produção/serverless, use o Session Pooler ou Transaction Pooler do Supabase.
DATABASE_URL=

# URL para Prisma CLI/migrations.
# Use Direct Connection em ambiente com IPv6 ou Session Pooler em IPv4.
DIRECT_URL=

# Opcional: habilita comprovantes privados de pagamento no Supabase Storage.
# Crie um bucket privado chamado payment-receipts ou altere o nome abaixo.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=payment-receipts
