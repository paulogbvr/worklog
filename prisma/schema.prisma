generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProjectConfigurationStatus {
  PENDING
  CONFIGURED
}

enum ProjectStatus {
  DEVELOPMENT
  IN_PROGRESS
  WAITING_CLIENT
  WAITING_PAYMENT
  PAUSED
  COMPLETED
  CANCELED
}

enum ClientStatus {
  ACTIVE
  NO_PROJECT
  NEGOTIATING
  PAUSED
  INACTIVE
}

enum BillingMode {
  HOURLY
  FIXED
}

enum SyncProvider {
  WAKATIME
}

enum NotificationType {
  SHARE_ACCESSED
  SHARE_COPIED
  SHARE_CREATED
  SHARE_PDF_DOWNLOADED
  PROJECT_STATUS_CHANGED
  PAYMENT_REMINDER_DUE
  ENV_WARNING
  SYNC_SUCCESS
  SYNC_ERROR
}

enum ProjectNoteType {
  FREE
  CHECKLIST
}

enum ReminderAmountMode {
  PENDING
  FIXED
}

enum ReminderStatus {
  ACTIVE
  SENT
  DISABLED
}

enum NotificationCategory {
  IMPORTANT
  UPDATE
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  TED
  CASH
  BOLETO
  OTHER
}

enum ShareEventType {
  ACCESS
  COPY_LINK
  PDF_DOWNLOAD
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  taxId     String?   @unique
  birthDate DateTime? @db.Date
  address   String?
  notes     String?
  status    ClientStatus?
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id                  String                     @id @default(cuid())
  clientId            String?
  client              Client?                    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  name                String
  notes               String?
  repositoryUrl       String?
  hourlyRate          Decimal?                   @db.Decimal(10, 2)
  dedicatedHourlyRate Decimal?                   @db.Decimal(10, 2)
  billDedicated       Boolean                    @default(false)
  billingMode         BillingMode                @default(HOURLY)
  fixedPrice          Decimal?                   @db.Decimal(12, 2)
  wakatimeProjectId   String?                    @unique
  wakatimeProjectName String?                    @unique
  active              Boolean                    @default(true)
  status              ProjectStatus              @default(IN_PROGRESS)
  configurationStatus ProjectConfigurationStatus @default(PENDING)
  lastSyncAt          DateTime?
  workLogEntries      WorkLogEntry[]
  wakatimeDays        WakaTimeProjectDay[]
  payments            Payment[]
  shareLinks          ShareLink[]
  notifications       Notification[]
  statusEvents         ProjectStatusEvent[]
  projectNotes        ProjectNote[]
  paymentReminder     PaymentReminder?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([clientId])
  @@index([active])
  @@index([configurationStatus])
}

model ProjectStatusEvent {
  id         String        @id @default(cuid())
  projectId  String
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStatus ProjectStatus?
  toStatus   ProjectStatus
  createdAt  DateTime      @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model WorkLogEntry {
  id              String   @id @default(cuid())
  operationId     String   @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([operationId])
  @@index([startedAt])
}

model WakaTimeProjectDay {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  totalSeconds Int
  syncedAt     DateTime @default(now())

  @@unique([projectId, date])
  @@index([date])
}

model Payment {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(10, 2)
  paidAt          DateTime
  method          PaymentMethod @default(OTHER)
  note            String?
  receiptPath     String?
  receiptData     Bytes?
  receiptName     String?
  receiptMimeType String?
  receiptSize     Int?
  invoiceKey      String?
  invoicePath     String?
  invoiceData     Bytes?
  invoiceName     String?
  invoiceMimeType String?
  invoiceSize     Int?
  whatsappNotifiedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([projectId])
  @@index([paidAt])
}

model ShareLink {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slug           String    @unique
  active         Boolean   @default(true)
  accessCount    Int       @default(0)
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  events         ShareEvent[]
  notifications  Notification[]

  @@index([projectId])
  @@index([active])
}

model Notification {
  id          String               @id @default(cuid())
  projectId   String?
  project     Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  shareLinkId String?
  shareLink   ShareLink?           @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  type        NotificationType
  category    NotificationCategory @default(IMPORTANT)
  title       String
  message     String
  readAt      DateTime?
  createdAt   DateTime             @default(now())

  @@index([createdAt])
  @@index([readAt])
  @@index([projectId])
  @@index([shareLinkId])
  @@index([category, readAt])
}

model ShareEvent {
  id          String         @id @default(cuid())
  shareLinkId String
  shareLink   ShareLink      @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  type        ShareEventType
  createdAt   DateTime       @default(now())

  @@index([shareLinkId])
  @@index([type])
  @@index([createdAt])
}

model SyncLog {
  id         String       @id @default(cuid())
  provider   SyncProvider
  startedAt  DateTime     @default(now())
  finishedAt DateTime?
  success    Boolean      @default(false)
  message    String?

  @@index([provider])
  @@index([startedAt])
}

model ProjectNote {
  id        String            @id @default(cuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String?
  content   String?
  type      ProjectNoteType   @default(FREE)
  position  Int               @default(0)
  items     ProjectNoteItem[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([projectId])
}

model ProjectNoteItem {
  id        String      @id @default(cuid())
  noteId    String
  note      ProjectNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  text      String
  completed Boolean     @default(false)
  position  Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([noteId])
}

model PaymentReminder {
  id            String             @id @default(cuid())
  projectId     String             @unique
  project       Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId      String?
  amountMode    ReminderAmountMode @default(PENDING)
  fixedAmount   Decimal?           @db.Decimal(12, 2)
  dueDate       DateTime
  message       String?
  status        ReminderStatus     @default(ACTIVE)
  sentAt        DateTime?
  notifiedDueAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([status])
  @@index([dueDate])
}
