# Chave da API do WakaTime
WAKATIME_API_KEY=

# URL de conexão do app com o PostgreSQL/Supabase.
# Em produção serverless, prefira o Transaction Pooler do Supabase.
DATABASE_URL=

# URL opcional para Prisma CLI/migrations.
# Use a Direct Connection se o ambiente tiver IPv6 ou o Session Pooler do Supabase em IPv4.
DIRECT_URL=
